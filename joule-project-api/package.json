{
  "name": "joule-project-api",
  "version": "0.1.0",
  "description": "CAP backend for the Procurement Copilot. Hosts LLM-backed actions (summarize, explain) callable from Joule as skill actions.",
  "private": true,
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@sap/cds": "^9",
    "@saptarishi/cds-plugin-llm": "^0.6.1",
    "express": "^4"
  },
  "engines": {
    "node": ">=18"
  },
  "cds": {
    "requires": {
      "llm": {
        "[development]": {
          "kind": "llm-groq",
          "modelId": "llama-3.3-70b-versatile"
        },
        "[ollama]": {
          "kind": "llm-ollama",
          "modelId": "qwen2.5:14b"
        },
        "[hybrid]": {
          "kind": "llm-anthropic",
          "modelId": "claude-opus-4-7"
        },
        "[production]": {
          "kind": "llm-groq",
          "modelId": "llama-3.3-70b-versatile"
        },
        "[genai-hub]": {
          "kind": "llm-genai-hub",
          "credentials": {
            "deploymentId": "<AICORE_DEPLOYMENT_ID>",
            "resourceGroup": "default"
          }
        }
      },
      "auth": {
        "[development]": { "kind": "dummy" },
        "[production]": { "kind": "dummy" }
      }
    }
  }
}
