{
  "name": "@saptarishi/cds-plugin-llm",
  "version": "0.6.0",
  "description": "LLM-agnostic AI service for SAP CAP. Speaks Anthropic, Ollama, Groq, any OpenAI-compatible endpoint, and SAP Generative AI Hub behind one API. Supports vision / multimodal input, streaming responses, structured outputs, tool use / function calling, and automatic retries with exponential backoff.",
  "main": "lib/index.js",
  "files": [
    "cds-plugin.js",
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.js",
    "example:procurement": "node examples/procurement-handler.js"
  },
  "keywords": [
    "sap",
    "cap",
    "cds",
    "llm",
    "ai",
    "anthropic",
    "claude",
    "ollama",
    "groq",
    "openai-compatible",
    "generative-ai-hub",
    "vision",
    "multimodal",
    "streaming",
    "joule"
  ],
  "author": "",
  "license": "Apache-2.0",
  "cds": {
    "requires": {
      "kinds": {
        "llm-anthropic": {
          "impl": "@saptarishi/cds-plugin-llm/lib/providers/anthropic.js",
          "model": "@saptarishi/cds-plugin-llm/lib/llm.cds"
        },
        "llm-ollama": {
          "impl": "@saptarishi/cds-plugin-llm/lib/providers/ollama.js",
          "model": "@saptarishi/cds-plugin-llm/lib/llm.cds"
        },
        "llm-genai-hub": {
          "impl": "@saptarishi/cds-plugin-llm/lib/providers/genai-hub.js",
          "model": "@saptarishi/cds-plugin-llm/lib/llm.cds"
        },
        "llm-groq": {
          "impl": "@saptarishi/cds-plugin-llm/lib/providers/groq.js",
          "model": "@saptarishi/cds-plugin-llm/lib/llm.cds"
        },
        "llm-openai-compatible": {
          "impl": "@saptarishi/cds-plugin-llm/lib/providers/openai-compatible.js",
          "model": "@saptarishi/cds-plugin-llm/lib/llm.cds"
        }
      }
    }
  },
  "peerDependencies": {
    "@sap/cds": ">=7"
  },
  "peerDependenciesMeta": {
    "@sap/cds": {
      "optional": false
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@sap/cds": "^9.9.2"
  }
}
